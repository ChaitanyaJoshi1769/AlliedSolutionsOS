# Application
NODE_ENV=development
LOG_LEVEL=debug

# API Service
API_PORT=3001
API_HOST=0.0.0.0
API_URL=http://localhost:3001
GRAPHQL_PATH=/graphql

# Web Dashboard
WEB_PORT=3000
WEB_URL=http://localhost:3000

# Admin Portal
ADMIN_PORT=3002
ADMIN_URL=http://localhost:3002

# Database - PostgreSQL
DATABASE_URL=postgresql://allied:allied123@localhost:5432/allied_os
DB_HOST=localhost
DB_PORT=5432
DB_USER=allied
DB_PASSWORD=allied123
DB_NAME=allied_os
DB_POOL_MIN=5
DB_POOL_MAX=20

# Database - Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Database - Neo4j (Fraud Detection)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=elastic123

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# OAuth2 (if using social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=allied-solutions-dev
AWS_S3_REGION=us-east-1

# AI/ML Services
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Email Service
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@alliedsolutions.com

# SMS Service (for OTP, alerts)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Third-party Integrations
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=allied-os
KAFKA_GROUP_ID=allied-os-consumer-group
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Monitoring & Observability
OTEL_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Feature Flags
FEATURE_AI_FRAUD_DETECTION=true
FEATURE_CLAIMS_AUTOMATION=true
FEATURE_DEALER_INTEGRATION=true
FEATURE_MOBILE_APP=true

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:3002
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your-session-secret-key

# Data Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key
DATA_ENCRYPTION_ENABLED=true

# Developer Settings
DEBUG=*:*
MOCK_EXTERNAL_SERVICES=false
SEED_TEST_DATA=true

# Tenant Configuration
MULTI_TENANCY_ENABLED=true
MAX_ORGANIZATIONS=100

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,xlsx,xls

# Cache Configuration
CACHE_TTL=3600
CACHE_ENABLED=true

# Rate Limiting
API_RATE_LIMIT=1000
API_RATE_WINDOW=3600

# Request Logging
REQUEST_LOG_ENABLED=true
REQUEST_LOG_BODY=false

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000
