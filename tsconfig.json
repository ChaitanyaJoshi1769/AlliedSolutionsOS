{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "baseUrl": ".",
    "paths": {
      "@allied/ui/*": ["packages/ui/src/*"],
      "@allied/config/*": ["packages/config/src/*"],
      "@allied/types/*": ["packages/types/src/*"],
      "@allied/fraud-engine/*": ["packages/fraud-engine/src/*"],
      "@allied/workflow-engine/*": ["packages/workflow-engine/src/*"],
      "@allied/analytics/*": ["packages/analytics/src/*"],
      "@allied/integrations/*": ["packages/integrations/src/*"],
      "@allied/auth/*": ["packages/auth/src/*"],
      "@allied/observability/*": ["packages/observability/src/*"],
      "@allied/api/*": ["services/api/src/*"],
      "@allied/ai/*": ["services/ai-services/src/*"],
      "@allied/worker/*": ["services/worker-service/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "coverage", ".next"]
}
