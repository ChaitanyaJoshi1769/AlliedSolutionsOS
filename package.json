{
  "name": "allied-solutions-os",
  "version": "1.0.0",
  "description": "AI-native operational intelligence and automation platform for lenders, insurers, and financial institutions",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules .pnpm-store dist coverage",
    "docs": "pnpm -r docs",
    "db:migrate": "pnpm -w --filter @allied/api db:migrate",
    "db:seed": "pnpm -w --filter @allied/api db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ]
}
