# AI Services Configuration
SERVICE_NAME=allied-ai-services
SERVICE_PORT=3005
LOG_LEVEL=info

# API Configuration
API_URL=http://localhost:3001
API_KEY=your-api-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/allied_os

# Redis
REDIS_URL=redis://localhost:6379

# LLM Configuration
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# ML Model Configuration
MODEL_PATH=./models
FRAUD_MODEL_VERSION=v1.0
RISK_MODEL_VERSION=v1.0

# OCR Configuration
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGES=eng

# Feature Flags
ENABLE_FRAUD_DETECTION=true
ENABLE_OCR=true
ENABLE_LLM=true
ENABLE_RECOMMENDATIONS=true

# Batch Processing
BATCH_SIZE=32
NUM_WORKERS=4

# Cache
CACHE_TTL=3600
CACHE_ENABLED=true
