{
  "name": "@allied/api",
  "version": "1.0.0",
  "description": "Allied Solutions OS - Core API Service",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "start": "nest start",
    "build": "nest build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "type-check": "tsc --noEmit",
    "db:migrate": "typeorm migration:run -d src/database/dataSource.ts",
    "db:migrate:create": "typeorm migration:create",
    "db:revert": "typeorm migration:revert -d src/database/dataSource.ts",
    "db:seed": "ts-node src/database/seeds/index.ts",
    "db:reset": "typeorm migration:revert -d src/database/dataSource.ts -a && typeorm migration:run -d src/database/dataSource.ts"
  },
  "dependencies": {
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/common": "^10.2.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.2.0",
    "@nestjs/typeorm": "^9.0.0",
    "apollo-server-express": "^4.9.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "graphql": "^16.8.0",
    "graphql-scalars": "^1.22.0",
    "ioredis": "^5.3.0",
    "kafka-node": "^5.0.0",
    "langchain": "^0.1.0",
    "neo4j-driver": "^5.13.0",
    "nestjs-typeorm-paginate": "^4.0.0",
    "@nestjs/throttler": "^5.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.40.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.45.0",
    "@opentelemetry/sdk-node": "^0.45.0",
    "@opentelemetry/sdk-trace-node": "^0.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.10.0",
    "pino": "^8.17.0",
    "pino-http": "^8.5.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.2.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^3.0.10",
    "@types/passport-local": "^1.0.35",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.4.0",
    "typescript": "^5.3.0"
  }
}
